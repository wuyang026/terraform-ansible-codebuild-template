# ==========================================
# DBサーバー共通設定
# ==========================================
[dbservers:vars]
# SSM接続を使用（SSH不要）
ansible_connection=aws_ssm

# AWSリージョン
ansible_region=ap-south-1

# SSMが一時ファイルを保存するS3バケット
ansible_aws_ssm_bucket_name=go-s3-bucket-test

# リモート側のPython実行パス（※3.9固定はNG）
ansible_python_interpreter=/usr/bin/python3